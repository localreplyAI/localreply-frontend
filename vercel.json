{
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/dashboard-configuration", "destination": "/dashboard-configuration.html" },
    { "source": "/dashboard-rendez-vous", "destination": "/dashboard-rendez-vous.html" },
    { "source": "/dashboard-messages", "destination": "/dashboard-messages.html" },
    { "source": "/dashboard-conversations", "destination": "/dashboard-messages.html" },
    { "source": "/dashboard-analytics", "destination": "/dashboard-analytics.html" },
    { "source": "/mon-compte", "destination": "/mon-compte.html" },
    { "source": "/abonnement", "destination": "/abonnement.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/features", "destination": "/features.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/demo", "destination": "/demo-chat.html" },
    { "source": "/chat", "destination": "/chat-client.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/gdpr", "destination": "/gdpr.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
