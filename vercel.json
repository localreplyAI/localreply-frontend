{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/dashboard-configuration", "destination": "/dashboard-configuration.html" },
    { "source": "/dashboard-rendez-vous", "destination": "/dashboard-rendez-vous.html" },
    { "source": "/dashboard-messages", "destination": "/dashboard-messages.html" },
    { "source": "/dashboard-conversations", "destination": "/dashboard-messages.html" },
    { "source": "/dashboard-analytics", "destination": "/dashboard-analytics.html" },
    { "source": "/mon-compte", "destination": "/mon-compte.html" },
    { "source": "/abonnement", "destination": "/abonnement.html" },
    { "source": "/choisir-plan", "destination": "/choisir-plan.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/features", "destination": "/features.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/demo", "destination": "/demo-chat.html" },
    { "source": "/chat", "destination": "/chat-client.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/gdpr", "destination": "/gdpr.html" },

    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/contact", "destination": "/:lang/contact.html" },

    { "source": "/:lang(fr|de|it|es|pt|nl|pl)", "destination": "/:lang/home.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/features", "destination": "/:lang/features.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/pricing", "destination": "/:lang/pricing.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/about", "destination": "/:lang/about.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/blog", "destination": "/:lang/blog.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/privacy", "destination": "/:lang/privacy.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/terms", "destination": "/:lang/terms.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/gdpr", "destination": "/:lang/gdpr.html" },

    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/auth", "destination": "/auth.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/onboarding", "destination": "/onboarding.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/mon-compte", "destination": "/mon-compte.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/abonnement", "destination": "/abonnement.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/choisir-plan", "destination": "/choisir-plan.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/reset-password", "destination": "/reset-password.html" },
    { "source": "/:lang(fr|de|it|es|pt|nl|pl)/forgot-password", "destination": "/forgot-password.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
